# Copy to .env.prod and fill in REAL values. Do NOT commit .env.prod (only this .example).
#   cp .env.prod.example .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# ---- Application database ----
DATABASE_NAME=passlify
DATABASE_USER=passlify
DATABASE_PASSWORD=change-me-strong-password

# ---- Keycloak database (separate from app DB) ----
KC_DB_NAME=keycloak
KC_DB_USER=keycloak
KC_DB_PASSWORD=change-me-strong-password

# ---- Keycloak admin (first boot) ----
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=change-me-strong-password

# ---- Keycloak public URL (behind your HTTPS reverse proxy) ----
KEYCLOAK_HOSTNAME=https://auth.passlify.rs

# ---- App -> Keycloak ----
# issuer becomes ${KEYCLOAK_HOSTNAME}/realms/passlify inside the app service

# ---- External SMTP (real provider; no mailpit in prod) ----
MAIL_HOST=email-smtp.eu-central-1.amazonaws.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
PASSLIFY_MAIL_FROM=tickets@passlify.rs

# ---- App secrets ----
PASSLIFY_QR_SECRET=change-me-min-32-bytes-secret-value!!
PASSLIFY_INVITE_SECRET=change-me-min-32-bytes-invite-value!!
APP_BASE_URL=https://api.passlify.rs

# ---- Raiffeisen via UPC e-Commerce Connect Gateway — disabled until merchant creds provisioned ----
RAIFFEISEN_ENABLED=false
RAIFFEISEN_GATEWAY_URL=https://ecommerce.raiffeisenbank.rs/go/enter
RAIFFEISEN_MERCHANT_ID=
RAIFFEISEN_TERMINAL_ID=
RAIFFEISEN_LOCALE=en
# PEM contents (private key PKCS#8; gateway public key or server certificate).
RAIFFEISEN_PRIVATE_KEY=
RAIFFEISEN_GATEWAY_PUBLIC_KEY=

# ---- Stripe — disabled until keys provisioned (use test-mode keys to verify) ----
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Manual (bank-transfer) payments ----
MANUAL_PAYMENT_HOLD_HOURS=72

# ---- Event auto-completion ----
EVENT_AUTO_COMPLETE_GRACE_HOURS=24
EVENT_AUTO_COMPLETE_INTERVAL_MS=3600000
