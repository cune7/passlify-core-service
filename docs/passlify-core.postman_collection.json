            }
          }
        }
      ]
    },
    {
      "name": "Custom Fields (ORGANIZER/ADMIN)",
      "item": [
        {
          "name": "Create custom field",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.collectionVariables.set('customFieldId', pm.response.json().id);"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
