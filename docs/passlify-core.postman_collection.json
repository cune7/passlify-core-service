            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/scan",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "scan"]
            },
            "description": "qrToken is the signed token encoded in the ticket's QR image (scanned at the gate). Always returns 200 — a denial is a verdict, not an error. Requires an OPERATOR/ADMIN token (set username=operator1 and re-run Get Token)."
          }
        },
