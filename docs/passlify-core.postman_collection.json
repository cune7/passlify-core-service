            "url": {
              "raw": "{{baseUrl}}/api/v1/custom-fields/{{customFieldId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "custom-fields", "{{customFieldId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Orders / Checkout (guest)",
      "item": [
        {
          "name": "Create order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.collectionVariables.set('orderId', pm.response.json().id);"]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"buyer\": {\n    \"email\": \"buyer@example.com\",\n    \"name\": \"Buyer One\",\n    \"fields\": {}\n  },\n  \"items\": [\n    {\n      \"ticketTypeId\": \"{{ticketTypeId}}\",\n      \"quantity\": 2\n    }\n  ],\n  \"returnUrl\": \"https://myapp.example.com/checkout/return\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "orders"]
            },
            "description": "Server-authoritative pricing — send only ticketTypeId + quantity. For EACH_TICKET ticket types, include one `attendees` entry per quantity unit, e.g. `\"attendees\":[{\"name\":\"A\",\"email\":\"a@x.com\",\"fields\":{\"tshirt_size\":\"M\"}}]`."
          }
        },
        {
          "name": "Get order",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "orders", "{{orderId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Payments (guest)",
      "item": [
        {
          "name": "Create payment session",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "pm.collectionVariables.set('sessionId', j.sessionId);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"successUrl\": \"https://myapp.example.com/checkout/success\",\n  \"cancelUrl\": \"https://myapp.example.com/checkout/cancel\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}/payment-session",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "orders", "{{orderId}}", "payment-session"]
            },
            "description": "Body optional. Returns checkoutUrl + sessionId. Redirect the buyer to checkoutUrl."
          }
        }
      ]
    },
    {
      "name": "Webhooks (signature, no JWT)",
      "item": [
        {
          "name": "Payment webhook (mock PAID)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Signature", "value": "", "description": "provider signature over the raw body", "disabled": true }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"PAID\",\n  \"sessionId\": \"{{sessionId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/{{provider}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhooks", "{{provider}}"]
            },
            "description": "For the MOCK provider, POST {type: PAID|FAILED, sessionId} to simulate the bank. Real providers verify X-Signature over the raw body."
          }
        }
      ]
    },
    {
      "name": "Tickets",
