            "description": "type: TEXT|TEXTAREA|EMAIL|PHONE|NUMBER|DATE|SELECT|CHECKBOX. scope: PER_PURCHASE (buyer) | PER_ATTENDEE. fieldKey: lowercase letters/digits/underscores."
          }
        },
        {
          "name": "List custom fields",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/events/{{eventId}}/custom-fields",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "events", "{{eventId}}", "custom-fields"]
            }
          }
        },
